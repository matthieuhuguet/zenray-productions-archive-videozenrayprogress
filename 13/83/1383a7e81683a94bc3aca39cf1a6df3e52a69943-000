    '74.0060°W', '2°21′E', '0.1278°W', '139.6917°E',
]
CODE_LINES = [
    '∑(x² + y²) = r²',
    'f(x) = e^(−x²/2σ²)',
    '∇²φ = ρ / ε₀',
    'dx/dt = −λx',
    '∫₀^∞ e^(−t) dt = 1',
    'P(A|B) = P(B|A)·P(A) / P(B)',
