import numpy as np, os, subprocess, random

W, H   = 1920, 1080
FPS    = 24
TOTAL  = FPS * 2   # 48 frames

OUT_DIR = '/tmp/glitch_frames'
OUT     = '/Users/zenray/Create/Build/Productions/VideoZenRayProgress/Frames_ZenRayProgress/Glitch Effect.mov'
FL      = '/Users/zenray/Library/Fonts/'

