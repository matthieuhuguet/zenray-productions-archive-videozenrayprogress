# ── Fonts ─────────────────────────────────────────────────────────────────────
F_HUGE  = ImageFont.truetype(FL+'AnthropicSerif-Medium.ttf',   360)
F_BIG   = ImageFont.truetype(FL+'AnthropicSerif-Regular.ttf',  180)
F_MED   = ImageFont.truetype(FL+'AnthropicSerif-Light.ttf',     80)
F_CODE  = ImageFont.truetype(FL+'AnthropicMono-Regular.ttf',    34)
F_SMALL = ImageFont.truetype(FL+'AnthropicMono-Light.ttf',      22)

# ── Contenu textuel ───────────────────────────────────────────────────────────
HUGE_WORDS = [
    'New York City', 'Tokyo', 'Berlin', 'São Paulo',
    'Hong Kong', 'Paris', 'Lagos', 'Montréal',
]
BIG_WORDS = [
    '7.07.2024', '23:47:11', '(00:45:33)', '3.14159',
    '2.71828', '48°51′N', '40.7128°N', '51.5074°N',
    'Im Höllental.', 'es Wort"', 'ch was.', '— sser',
