    'REF: 2024.07.02 — 23:47',
    'SESSION ID: f3a7-0091',
    'EXPOSURE: 1/250s f/1.8',
]

# ── Palettes ───────────────────────────────────────────────────────────────────
WHITE   = (240, 240, 240)
RED     = (195,  91,  83)   # #c35b53
DARKRED = (130,  25,  20)
BLACK   = ( 10,  10,  10)
COLORS  = [RED, RED, WHITE, BLACK, DARKRED]

# ── Helpers ───────────────────────────────────────────────────────────────────
def rotated_text(word, font, color, alpha, angle):
    """Rend un mot dans un calque RGBA, tourné autour de son centre."""
    tmp = Image.new("RGBA", (W, H), (0,0,0,0))
    bb  = font.getbbox(word)
    cx  = (W - (bb[2]-bb[0])) // 2
    cy  = (H - (bb[3]-bb[1])) // 2
    ImageDraw.Draw(tmp).text((cx, cy), word, font=font, fill=(*color, alpha))
    return tmp.rotate(angle, resample=Image.BICUBIC)

def draw_frame(seed):
    rng = random.Random(seed)
    img = Image.new("RGBA", (W, H), (0,0,0,0))
    draw = ImageDraw.Draw(img)

    # ── 1. Scan lines horizontales ────────────────────────────────────────────
    for _ in range(rng.randint(3, 12)):
        y   = rng.randint(0, H)
        h   = rng.randint(1, 10)
        col = rng.choice(COLORS)
        alp = rng.randint(30, 130)
        draw.rectangle([0, y, W, y+h], fill=(*col, alp))

    # ── 2. Blocs géométriques ─────────────────────────────────────────────────
    for _ in range(rng.randint(2, 7)):
        x1  = rng.randint(0, W-20)
        y1  = rng.randint(0, H-20)
        x2  = x1 + rng.randint(10, 400)
        y2  = y1 + rng.randint(2, 60)
        col = rng.choice(COLORS)
        alp = rng.randint(20, 90)
        draw.rectangle([x1, y1, x2, y2], fill=(*col, alp))

    # ── 3. Barcodes ───────────────────────────────────────────────────────────
    for _ in range(rng.randint(0, 3)):
        bx  = rng.randint(0, W-250)
        by  = rng.randint(0, H-180)
        bh  = rng.randint(60, 180)
        col = rng.choice([WHITE, RED])
        alp = rng.randint(80, 200)
        for _ in range(rng.randint(6, 22)):
            lx = bx + rng.randint(0, 200)
            lw = rng.randint(2, 14)
            draw.rectangle([lx, by, lx+lw, by+bh], fill=(*col, alp))

    # ── 4. Texte CODE (petites lignes) ────────────────────────────────────────
    for _ in range(rng.randint(2, 6)):
        cx  = rng.randint(0, W-600)
        cy  = rng.randint(0, H-200)
        col = rng.choice(COLORS)
        alp = rng.randint(100, 220)
        for i in range(rng.randint(1, 6)):
            line = rng.choice(CODE_LINES)
            draw.text((cx, cy+i*38), line, font=rng.choice([F_CODE, F_SMALL]),
                      fill=(*col, alp))

    # ── 5. Mots BIG ───────────────────────────────────────────────────────────
    for _ in range(rng.randint(2, 5)):
        word = rng.choice(BIG_WORDS)
        x    = rng.randint(-50, W-300)
        y    = rng.randint(-20, H-100)
        col  = rng.choice(COLORS)
        alp  = rng.randint(80, 230)
        draw.text((x, y), word, font=F_MED, fill=(*col, alp))

    # ── 6. Mot HUGE tourné ────────────────────────────────────────────────────
    if rng.random() < 0.65:
        word  = rng.choice(HUGE_WORDS)
        angle = rng.choice([0, 0, 90, -90, rng.randint(-20, 20)])
        col   = rng.choice([WHITE, RED, DARKRED])
        alp   = rng.randint(40, 160)
        layer = rotated_text(word, rng.choice([F_HUGE, F_BIG]), col, alp, angle)
        # Décaler aléatoirement
        dx = rng.randint(-400, 400)
        dy = rng.randint(-300, 300)
        img.alpha_composite(layer, (max(0,dx), max(0,dy)) if dx>=0 and dy>=0
                            else (0,0))

    # ── 7. Aberration : décalage rouge/noir ──────────────────────────────────
    if rng.random() < 0.45:
        shift = rng.randint(3, 18)
        arr   = np.array(img)
        ghost = np.zeros_like(arr)
        ghost[:, shift:, 0] = arr[:, :-shift, 0]
        ghost[:, shift:, 3] = (arr[:, :-shift, 3] * 0.35).astype(np.uint8)
        img.alpha_composite(Image.fromarray(ghost, 'RGBA'))

    # ── 8. Flash rouge ou noir ────────────────────────────────────────────────
    if rng.random() < 0.12:
        col = rng.choice([RED, BLACK])
        alp = rng.randint(8, 30)
        draw.rectangle([0, 0, W, H], fill=(*col, alp))

    return img

# ── Render ────────────────────────────────────────────────────────────────────
rng_main = random.Random(42)
for frame in range(TOTAL):
    seed = rng_main.randint(0, 2**31)
    draw_frame(seed).save(f"{OUT_DIR}/frame_{frame:04d}.png")

